generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Barbershop {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  phone     String
  createdAt DateTime @default(now())

  themeConfigs ThemeConfig[]
  locations    BarbershopLocation[]
  users        User[]
}

model ThemeConfig {
  id           String @id @default(uuid())
  style        String
  baseColor    String
  theme        String
  font         String
  radius       String

  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
}

model BarbershopLocation {
  id            String   @id @default(uuid())
  country       String
  state         String
  city          String
  address       String?
  postalCode    String?
  maxDistancia  Decimal  @default(100.0)
  createdAt     DateTime @default(now())

  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password      String
  avatar        String?
  phone         String?
  role          UserRole
  active        Boolean  @default(true)
  barbershopId  String?
  barbershop    Barbershop? @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt            DateTime    @updatedAt
}


enum UserRole {
  ADMIN
  BARBER
  CLIENT
}